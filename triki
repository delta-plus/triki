#!/bin/bash

read -r -d '' usage << EOF
  ______     _ __   _ 
 /_  __/____(_) /__(_)
  / / / ___/ / //_/ / 
 / / / /  / / , \/ /  
/_/ /_/  /_/_/|_/_/   
                      
Text Retrieval - Wikipedia

Usage: triki (options) [input] [search] (processes)

[input] can be a file or a Wikipedia URL.
Triki will use the URLs found at [input].

Options:
-c - Compact. Doesn't add newlines between hits.
-i - Include input URL at the top of the search list.
-n - No sort. Search URLs in the order they are found.
-q - Quiet. Doesn't print article titles.
-r - Reassemble quotes with multiple sentences.
-s - Single URL. Searches only the provided URL.
EOF

mkbox() {
read -r -d '' pytxt << EOF
import sys

def bold(text):
  return f"\\033[1m{text}\\033[0m"

def mkbox(val, style, line):
  vlen = len(val)
  cols = vlen + 2

  if style == '-b':
    val = bold(val)
    h = 'Ōöü'
    v = 'Ōöā'
    lt = 'ŌöŻ'
    rt = 'Ōö½'
    ut = 'Ōö│'
    dt = 'Ōö╗'
    ct = 'ŌĢŗ'
    c1 = 'ŌöÅ'
    c2 = 'Ōöō'
    c3 = 'ŌöŚ'
    c4 = 'Ōöø'
  else:
    h = 'ŌöĆ'
    v = 'Ōöé'
    lt = 'Ōö£'
    rt = 'Ōöż'
    ut = 'Ōö¼'
    dt = 'Ōö┤'
    ct = 'Ōö╝'
    c1 = 'Ōöī'
    c2 = 'ŌöÉ'
    c3 = 'Ōöö'
    c4 = 'Ōöś'

  sect = h * cols
  if cols % 2 == 0:
    line_s = h * int(cols / 2 - 1) + ut + h * int(cols / 2)
  else:
    line_s = h * int(cols / 2) + ut + h * int(cols / 2)

  if line == 'n':
    top = f"{c1}{sect}{c2}"
    mid = f"\\n{v} {val} {v}"
    bot = f"\\n{c3}{sect}{c4}"
  elif line == 'e':
    top = f"{c1}{sect}{c2}"
    mid = f"\\n{v} {val} {v}"
    bot = f"\\n{c3}{sect}{c4}"
  elif line == 's':
    top = f"{c1}{sect}{c2}"
    mid = f"\\n{v} {val} {v}"
    bot = f"\\n{c3}{line_s}{c4}"
  elif line == 'w':
    top = f"{c1}{sect}{c2}"
    mid = f"\\n{v} {val} {v}"
    bot = f"\\n{c3}{sect}{c4}"
  else:
    top = f"{c1}{sect}{c2}"
    mid = f"\\n{v} {val} {v}"
    bot = f"\\n{c3}{sect}{c4}"

  return f"{top}{mid}{bot}"

if sys.argv[1] == '-b':
  print(mkbox(sys.argv[2], '-b', ''))
elif sys.argv[1] == '-h':
  print(mkbox(sys.argv[3], '', sys.argv[2]))
else:
  print(mkbox(sys.argv[1], '', ''))
EOF

  python3 -c "$pytxt" $@
}

dedupe() {
  # Removes duplicates without sorting
  input=$(</dev/stdin)
  echo "$input" | awk '!seen[$0]++'
}

requote() {
read -r -d '' pytxt << EOF
import sys

buf = ''

for line in map(str, sys.stdin):
    line = line.rstrip()

    if len(buf) == 0:
        if line.count('"') % 2:
            buf += line.rstrip() + ' '
        else: 
            print(line)
    else:
        buf += line.rstrip() + ' '
        if line.count('"') % 2:
          print(buf.rstrip())
          buf = ''
EOF

  input=$(</dev/stdin)
  echo "$input" | python3 -c "$pytxt"
}

search() {
  # Custom User-Agent added to comply with Wikipedia scraper guidelines
  # To be polite, do not use more than ~5 procs
  # Ugly, isn't it? But as far as sentence parsers go, it's pretty robust!
  res=$(curl -s -H 'User-Agent: Triki (just another Wiki-bot) v5.23 by delta-plus (j03grassl@gmail.com)' "$1" \
    | pup 'p text{}' \
    | perl -MHTML::Entities -pe 'decode_entities($_);' \
    | rg -v '^[\s]*$' \
    | sd "\n(['\"])" '$1' \
    | sd '\n' ' ' \
    | sd "ŌĆÖ" "'" \
    | sd '\.\[[^a-zA-Z]+\]' '\.\n' \
    | sd ' \[[^a-zA-Z]+\] ' ' ' \
    | sd '([,;:])\n' '$1 ' \
    | sd '([A-Z])\.([A-Z])\.([A-Z]?)[.]?' '$1$2$3' \
    | sd '\. ' '.\n' \
    | sd '( [A-Z]?[a-z]?[a-z].)\n' '$1 ' \
    | sd '\n([A-Z]\.)\n' ' $1 ' \
    | sd '( [A-Z]\.)\n' '$1 ' \
    | sd '( [ai][tn]\.) ' '$1\n' \
    | sd ' " ' '" ' \
    | sd '[ ]+' ' ' \
    | sd ' \.$' '.' \
    | sd '\n([a-z])' ' $1' \
    | sd '\n(.)$' '$1' \
    | sd '^:[\s]*[^\s]+[\s]+' '' \
    | sd " 's" "'s" \
    | sd '([A-Za-z])- ' '$1-' \
    | sd ' \-([A-Za-z])' '\-$1' \
    | sd '\( ' '(' \
    | sd ' \)' ')' \
    | sd ' ([,;:]) ' '$1 ' \
    | sd '\.mw-parser-output[^}]+\}' '' \
    | sd "([.\!?][']?\")" '$1\n' \
    | sd '^[ ]+' '' \
    | sd '[ ]+$' '') 

  if [[ "$rqte" -eq 0 ]]; then
    res=$(echo "$res" | rg "$2")
  else
    res=$(echo "$res" | requote | rg "$2")
  fi

  if [[ -n "$res" ]]; then
    if [[ "$shhh" -eq 0 ]]; then
      mkbox -b "$(echo "$1" | sd '.*/' '' | sd '_' ' ' | python3 -c "import sys, urllib.parse; [print(urllib.parse.unquote(line.rstrip('\n'))) for line in sys.stdin]")"
    fi
    if [[ "$cmpc" -eq 0 ]]; then
      echo "$res" | sd '\n' '\n\n' | rg --no-context-separator -A 1 "$2"
    else
      echo "$res" | rg "$2"
    fi
  fi
}

export -f search

OPTIONS=$(getopt -o cinqrsh --long help -- "$@" 2>/dev/null)

cmpc=0
incl=0
nsrt=0
shhh=0
rqte=0
sngl=0

while getopts 'cinqrsh' opt; do
  case ${opt} in
    c) cmpc=1 ;;
    i) incl=1 ;;
    n) nsrt=1 ;;
    q) shhh=1 ;;
    r) rqte=1 ;;
    s) sngl=1 ;;
    h) echo "    $usage"; echo; exit 1 ;;
  esac
done 2>/dev/null

export cmpc
export incl
export nsrt
export shhh
export rqte
export sngl

shift $((OPTIND - 1))

if ! [[ -f "$1" || "$1" =~ ^https?://..\.wikipedia.org ]] || ! [[ "$#" -ge 2 ]]; then
  echo "  $usage"; echo; exit 1
fi

if [[ -f "$1" ]]; then
  if cat "$1" | rg '/wiki/'; then
    temp=$(mktemp)
    cat "$1" | sd '/wiki/' '/api/rest_v1/page/html/' > "$temp"
    input="$temp"
  else
    input="$1"
  fi
else
  temp=$(mktemp)
  if [[ "$incl" -eq 1 ]] || [[ "$sngl" -eq 1 ]]; then
    src=$(echo "$1" | sd '/wiki/' '/api/rest_v1/page/html/')
    echo "$src" > "$temp"
  fi
  if [[ "$sngl" -eq 0 ]]; then
    if [[ "$nsrt" -eq 0 ]]; then
      curl -s "$1" | pup 'a attr{href}' | grep '^/wiki/' | grep -v ':' | sed 's|^|https://en.wikipedia.org|; s|#.*||' | sort -u | sd '/wiki/' '/api/rest_v1/page/html/' | rg -v "^$src$" >> "$temp"
    else
      curl -s "$1" | pup 'a attr{href}' | grep '^/wiki/' | grep -v ':' | sed 's|^|https://en.wikipedia.org|; s|#.*||' | dedupe | sd '/wiki/' '/api/rest_v1/page/html/' | rg -v "^$src$" >> "$temp"
    fi
  fi
  input="$temp"
fi

if [[ -z "$3" ]]; then
  procs=1
else
  procs="$3"
fi

parallel -j "$procs" -u search {} "'$2'" :::: "$input"

if [[ -f "$temp" ]]; then
  rm "$temp"
fi
